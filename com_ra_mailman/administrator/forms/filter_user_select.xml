<?xml version="1.0" encoding="utf-8"?>
<form>
    <fields name="filter">
        <field name="search" type="text" 
               description="Search term"
               label="COM_USERS_FILTER_SEARCH_DESC"
               class="js-stools-search-string" />

          <field name="method_id"
            label="Method"
            description="Mode of subscription"
            type="sql"    
            query="SELECT id AS value, name AS method_id FROM `#__ra_mail_methods`"
            keyfield="id"
            header="- Select method -"
            input_type="list" 
            class="js-select-submit-on-change"
            />          

    </fields>

    <fields name="list">

        <field name="fullordering"
               type="list"
               label="COM_RA_MAILMAN_LIST_FULL_ORDERING"
               description="COM_RA_MAILMAN_LIST_FULL_ORDERING_DESC"
             class="js-select-submit-on-change"
               default="a.id DESC"
        >
            <option value="">JGLOBAL_SORT_BY</option>
            <option value="a.home_group ASC">Group Ascending</option>
            <option value="a.home_group DESC">Group Descending</option>
            <option value="p.preferred_name ASC">Name Ascending</option>
            <option value="p.preferred_name DESC">Name Descending</option>
            <option value="u.email ASC">Email Ascending</option>
            <option value="u.email DESC">Email Descending</option>

        </field>

       <field name="limit"
               type="limitbox"
               label="COM_RA_MAILMAN_LIST_LIMIT"
               description="COM_RA_MAILMAN_LIST_LIMIT_DESC"
               class="input-mini js-select-submit-on-change"
               default="25"
        />
    </fields>
</form>