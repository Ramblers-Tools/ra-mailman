<?xml version="1.0" encoding="utf-8"?>
<form addfieldprefix="Ramblers\Component\Ra_tools\Administrator\Field">
  <fieldset addruleprefix="Ramblers\Component\Ra_tools\Administrator\Rule">
       <field name="id" type="text" default="0" label="ID"
            readonly="true" class="readonly"
            description="JGLOBAL_FIELD_ID_DESC" /> 
        <field
            name="title"
            type="textfield"
            label="Title"
            description="Title for the mailshot"
            required="true"
            class="input-xxlarge"
            default=""
            />

        <field
            name="body"
            type="editor"
            label="Content"
            description="Content of the email"
            filter="raw"
            required="true"
            default=""
            />

        <field
            name="date_sent"
            type="calendar"
            label="Date sent"
            description="Date of most recent mailing"
            default=""
            readonly="true"
            />
        <field
            name="mail_list_id"
            type="hidden"
            label="Mailing list ID"
            description="id of the mailing list"
            required="false"
            />
        <field
            name="mail_list_name"
            type="foreignkey"
            label="Mailing list"
            description="name of the mailing list"
            table="#__ra_mail_lists"
            key="id"
            value="CONCAT(group_code, ':', name)"
            default="" 
            />
        <field
           name="contact_id"
           type="sql"
           label="Normally, when a recipient replies to a Mailshot it will go the the Author of the
           list, but you can select a different Contact"
           query="
               SELECT u.id AS value, c.name AS text
               FROM #__users AS u
               INNER JOIN #__contact_details AS c
                   ON c.user_id = u.id
               UNION
               SELECT 0, '--Select Contact --'
               ORDER BY text"
           key_field="value"
           value_field="text"
       />     
       <field
        name="reply_to"
        type="text"
        label="Email"
        description="Alternative recipient for the reply"
        required="false"
        readonly="true"
        />
        <field
            name="event_id"
            type="event" 
            label="Invitation list"
            description="If selected, an invitation will be included to book on this list"
            sql_select="id, title"     
            sql_from="`#__ra_events`"
            sql_where="bookable=1 "  
            sql_order="title"
            key_field="id"
            value_field="title"
        />   
        <field
            name="state"
            type="list"
            label="Status"
            description="Active/Deleted"
            class="inputbox"
            size="1"
            default="1"
            >
            <option value="1">Active</option>
            <option value="0">Deleted</option>
           </field>
        <field
            name="attached_file"
            type="hidden"
            label="File to be attached"
            description="Hidden field"
            default=""
            />
        <field
            name="attachment"
            type="file"
            multiple="true"
            label="Attachment"
            description="Name of the data file you have uploaded"
       />   
       <field
            name="created"
            type="calendar"
            label="Created"
            description="Date created"
            readonly="true"
            timeformat="24" 
            filter="user_utc" 
            format="%H:%M.%S %d-%m-%Y"   
            default=""
            />
       <field
            name="created_by"
            type="user"
            label="Created by"
            description="User that created the record"
            readonly="true"
            default=""
            />
       <field
            name="modified"
            type="calendar"
            label="Updated"
            readonly="true"
            timeformat="24" 
            filter="user_utc" 
            format="%Y-%m-%d %H:%M.%S"   
            default=""
            />
       <field
            name="modified_by"
            type="user"
            label="Updated by"
            description="User that last updated the record"
            readonly="true"
            default=""
            />
  </fieldset>
</form>
